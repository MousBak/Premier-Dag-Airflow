# Copy this file to .env and fill in the values
# .env is never committed (see .gitignore)

# PostgreSQL — weather data database
METEO_DB_HOST=localhost
METEO_DB_PORT=5432
METEO_DB_NAME=meteo_db
METEO_DB_USER=postgres
METEO_DB_PASSWORD=your_password_here

# MinIO — object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_secret_here
MINIO_BUCKET_BRONZE=meteo-bronze
MINIO_BUCKET_SILVER=meteo-silver

# Airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_PASSWORD=admin
